# =============================================================================
# Backend Django + Postgres (docker compose nesta pasta)
# Copie: cp .env.example .env   e edite valores (nunca commite o .env com segredos reais).
# =============================================================================

# --- PostgreSQL (serviço `db` no docker-compose) ---
POSTGRES_USER=cedula
POSTGRES_PASSWORD=cedula_altere_esta_senha
POSTGRES_DB=cedula
POSTGRES_PUBLISH_PORT=5433

# --- Django (obrigatório para o compose: DJANGO_SECRET_KEY) ---
# O compose mapeia DJANGO_SECRET_KEY → SECRET_KEY dentro do contentor.
# Para `manage.py` na máquina: basta DJANGO_SECRET_KEY (settings aceita como fallback).
DJANGO_SECRET_KEY=gere_uma_chave_longa_e_aleatoria
DJANGO_DEBUG=false

# Host header permitido (inclua host.docker.internal se o Next em Docker chamar a API por esse nome).
ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal

# Nginx HTTPS na frente (VPS / Hostinger) — cookies seguros e X-Forwarded-Proto
# BEHIND_HTTPS_PROXY=true

# Onde o Gunicorn fica mapeado no host: ip:porta_host (por defeito no compose: 127.0.0.1:8005).
# Para ouvir em todas as interfaces: BACKEND_PUBLISH=0.0.0.0:8005
# BACKEND_PUBLISH=127.0.0.1:8005

# --- Base de dados Django (fora do contentor: ex. migrate na máquina contra o Postgres do compose) ---
# Dentro do Docker o compose define DB_* automaticamente. Só precisa disto se correr Django no host.
USE_SQLITE=false
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=cedula
DB_USER=cedula
DB_PASSWORD=cedula_altere_esta_senha

# --- Superutilizador inicial (ensure_bootstrap_superuser no arranque do contentor) ---
# Se já existir este e-mail ativo como superuser+staff, não altera. Senão cria ou promove.
INIT_SUPERUSER_EMAIL=agencia.prodosdigital@gmail.com
INIT_SUPERUSER_PASSWORD=123senha

# --- Opcional: caminhos do pg_dump/psql no host (admin backup/restore). No contentor usa o cliente PG 17. ---
# PG_DUMP_BIN=/opt/homebrew/opt/postgresql@17/bin/pg_dump
# PSQL_BIN=/opt/homebrew/opt/postgresql@17/bin/psql

# Opcional: repor schema public antes do import SQL no admin (dump completo pg_dump).
# true = apaga tudo em public e o dump recria tabelas + COPY/INSERT (evita "already exists" e dados em falta).
# PG_RESTORE_RESET_PUBLIC_SCHEMA=true

# Opcional: schemas extra a DROP antes do import SQL no admin (CSV; regex segura [A-Za-z0-9_-]).
# PG_RESTORE_PREAMBLE_EXTRA_SCHEMAS=meu_schema,legacy_x
